# ============================================================
# .claudeignore - Koperasi Kita
# File/folder yang TIDAK perlu dibaca Claude saat bekerja.
# Tujuan: hemat token, fokus ke source code yang relevan.
# ============================================================

# ---------- Version control ----------
.git/
.gitignore

# ---------- Gradle / Android build artifacts ----------
.gradle/
build/
app/build/
app/.gradle/
gradle/
gradlew
gradlew.bat
*.aab
*.apk
*.ap_
*.dex
*.class
output-metadata.json
captures/
.externalNativeBuild/
.cxx/
*.hprof

# ---------- Android / Kotlin intermediate ----------
app/release/
app/debug/
app/src/main/res/drawable-*/
app/src/main/res/mipmap-*/
app/proguard-rules.pro
local.properties

# ---------- IDE / Editor ----------
.idea/
*.iml
misc.xml
deploymentTargetDropDown.xml
render.experimental.xml
.vscode/
*.swp
*.swo

# ---------- Keystore / Signing (JANGAN pernah dibaca) ----------
*.jks
*.keystore
*.p12
*.pfx
keystore.properties

# ---------- Secrets / Credentials (JANGAN pernah dibaca) ----------
google-services.json
GoogleService-Info.plist
serviceAccountKey.json
firebase-adminsdk-*.json
.env
.env.*
*.pem
*.key

# ---------- Node / Next.js ----------
node_modules/
**/node_modules/
.next/
buku-pokok-web/.next/
buku-pokok-web/out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ---------- Firebase cache & emulator ----------
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
database-debug.log
ui-debug.log
pubsub-debug.log
.runtimeconfig.json

# ---------- Cloud Functions build ----------
functions/node_modules/
functions/lib/
functions/dist/
functions/package-lock.json

# ---------- OS files ----------
.DS_Store
Thumbs.db
desktop.ini
*~

# ---------- Log files ----------
*.log
logs/

# ---------- RTDB export JSON (sangat besar, ~800KB) ----------
# File ini hanya snapshot data, bukan source. Struktur RTDB
# sudah didokumentasikan di CLAUDE.md dan rulesfirebase.txt.
koperasikitagodangulu-default-rtdb-*.json
*-default-rtdb-*.json
*rtdb-export*.json

# ---------- Duplikat / backup file ----------
.firebaserc.txt
*.bak
*.backup
*.orig
*.rej

# ---------- Generated / temporary ----------
tmp/
temp/
.cache/
coverage/
.nyc_output/
*.tsbuildinfo

# ---------- Binary / media besar ----------
*.zip
*.tar
*.tar.gz
*.rar
*.7z
*.mp4
*.mov
*.avi
*.psd
*.ai

# ---------- Misc ----------
*.pyc
__pycache__/
